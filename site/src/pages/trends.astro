---
import { existsSync, readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import Base from '../layouts/Base.astro';
import TrendCharts from '../components/TrendCharts';
import type { Stats } from '../components/TrendCharts';

// ---------------------------------------------------------------------------
// stats.json is a HARD build dependency — it is generated by scripts/stats.py
// (Phase 2). There is no inline-compute fallback: if the file is absent, the
// build MUST fail loudly rather than silently shipping an empty Trends page.
//
// Resolve against process.cwd() (the site/ project root the build runs from),
// NOT import.meta.url — this page is bundled into dist/ and import.meta.url
// would point inside the build output rather than at the source file.
// ---------------------------------------------------------------------------
const STATS_PATH = resolve(process.cwd(), 'src/data/stats.json');

if (!existsSync(STATS_PATH)) {
  throw new Error(
    `[trends.astro] Required stats file not found: ${STATS_PATH}\n` +
      `Generate it before building the site: run \`python scripts/stats.py\`.`,
  );
}

let stats: Stats;
try {
  stats = JSON.parse(readFileSync(STATS_PATH, 'utf-8')) as Stats;
} catch (err) {
  throw new Error(
    `[trends.astro] Failed to parse ${STATS_PATH}: ${(err as Error).message}`,
  );
}

// Sanity-check the shape so a malformed stats file also fails the build.
for (const key of [
  'papers_per_year',
  'method_family_by_year',
  'subfield_distribution',
] as const) {
  if (!stats[key] || typeof stats[key] !== 'object') {
    throw new Error(`[trends.astro] stats.json is missing required key "${key}".`);
  }
}

const totals = stats.totals ?? { papers: 0, milestones: 0, subfields: 0 };
---

<Base
  title="Trends"
  description="Statistical trend charts for radio map estimation research — papers per year, method family evolution, and subfield distribution."
>
  <section aria-labelledby="tr-heading">
    <h1 id="tr-heading">Trend Charts</h1>
    <p>
      Quantitative views of the radio map estimation corpus, aggregated at build time from the
      paper data. The charts below cover publication volume over time, the changing mix of method
      families, and how papers are spread across the four subfields.
    </p>
    <p class="text-muted">
      Aggregated from {totals.papers} papers ({totals.milestones} milestones) across {totals.subfields}
      subfields.
    </p>

    <TrendCharts stats={stats} client:load />

    <p class="text-muted trends-note">
      Charts are interactive (hover for exact values) and rendered with recharts. The underlying
      data is generated by <code>scripts/stats.py</code> into <code>site/src/data/stats.json</code>.
    </p>
  </section>
</Base>

<style is:global>
  /* Styling for the TrendCharts island (global so it reaches the React DOM). */
  .trend-charts {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .chart-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin: 0;
  }
  .chart-card__title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .chart-card__desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0.25rem 0 0.75rem;
  }
  .chart-card__plot {
    width: 100%;
  }
  /* recharts renders inline SVG text; keep it readable on dark backgrounds. */
  .chart-card .recharts-text {
    fill: var(--color-text-muted);
  }
  .chart-card .recharts-cartesian-axis-line,
  .chart-card .recharts-cartesian-axis-tick-line {
    stroke: var(--color-border);
  }
</style>

<style>
  .trends-note {
    font-size: 0.85rem;
    margin-top: 1.5rem;
  }
</style>
